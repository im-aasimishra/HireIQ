# ==============================================================================
# HireIQ Environment Variables Template
# ==============================================================================

# --- PostgreSQL Configuration ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=hireiq
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Redis Configuration ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- MongoDB Configuration ---
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=admin
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=hireiq

# --- Qdrant Configuration ---
QDRANT_HOST=localhost
QDRANT_PORT=6333

# --- Neo4j Configuration ---
NEO4J_AUTH=neo4j/password123
NEO4J_HOST=localhost
NEO4J_PORT=7687

# --- NextAuth Configuration ---
# Generate a random 32-character secret string using `openssl rand -hex 32`
NEXTAUTH_SECRET=some-secret-key-at-least-32-chars-long
NEXTAUTH_URL=http://localhost:3000

# --- General System Configurations ---
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Core Intelligence Layer Configuration ---
OPENAI_API_KEY=
QDRANT_URL=http://qdrant:6333
MONGO_URL=mongodb://mongo:27017
REDIS_URL=redis://redis:6379
CLAMAV_HOST=clamav
EMBEDDING_MODEL=text-embedding-3-large
FALLBACK_EMBEDDING_MODEL=BAAI/bge-m3
